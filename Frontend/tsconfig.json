{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "src/pages/home/components/About.jsx", "src/pages/home/components/CTA.jsx", "src/pages/home/components/FAQ.jsx", "src/pages/home/components/Features.jsx", "src/pages/home/components/Footer.jsx", "src/pages/home/components/Hero.jsx", "src/pages/home/components/Navbar.jsx", "src/App.jsx"],
  "exclude": ["node_modules"]
}
